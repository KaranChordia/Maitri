{
  "buildCommand": "cd 09_demos/maitri-circle && npm install && MAITRI_BASE_PATH=/ npm run build",
  "outputDirectory": "09_demos/maitri-circle/dist",
  "cleanUrls": false,
  "trailingSlash": false,
  "rewrites": [
    {
      "source": "/characters",
      "destination": "/characters.html"
    },
    {
      "source": "/story-universe",
      "destination": "/story-universe.html"
    }
  ]
}
